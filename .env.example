# Core AI settings
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# App behavior
DEBUG=false
MAX_FILE_SIZE_MB=10
MAX_ML_ROWS=5000
OPENAI_TIMEOUT=30
CORS_ORIGINS=http://127.0.0.1:8001,http://localhost:8001
CORS_ALLOW_CREDENTIALS=false

# Optional API key auth (service-to-service)
DQA_API_KEY=

# Optional session auth
AUTH_REQUIRED=false
AUTH_USER=admin
AUTH_PASSWORD=
SESSION_TTL_MINUTES=120

# Reliability and rate limits
ANALYZE_TIMEOUT_SEC=120
TRANSFORM_TIMEOUT_SEC=90
TRANSFORM_RETRY_COUNT=1
RATE_LIMIT_ANALYZE_PER_MIN=20
RATE_LIMIT_AI_PER_MIN=30
